<dialog
  id="edit-category-modal"
  class="m-auto w-[min(92vw,400px)] rounded-2xl border border-line bg-surface p-0 text-ink shadow-2xl shadow-black/40 backdrop:bg-black/70"
  aria-label="Editar nombre de categoría"
>
  <form id="edit-category-form" class="space-y-4 p-6">
    <div>
      <h3 class="font-display text-2xl tracking-wide text-ink">Editar Categoría</h3>
      <p class="mt-1 text-sm text-ink-muted">Cambia el nombre de la categoría seleccionada.</p>
    </div>

    <input id="edit-category-id" type="hidden" />

    <label class="grid gap-2 text-sm">
      <span class="text-ink-muted">Nuevo nombre</span>
      <input
        id="edit-category-name"
        type="text"
        required
        minlength="2"
        maxlength="50"
        class="min-h-11 rounded-lg border border-line bg-surface-elevated px-4 text-sm text-ink outline-none transition-colors focus:border-accent"
      />
    </label>

    <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:justify-end">
      <button
        id="cancel-edit-category-modal"
        type="button"
        class="inline-flex min-h-11 items-center justify-center rounded-lg border border-line bg-surface px-5 text-sm font-medium text-ink-muted transition-colors hover:text-ink"
      >
        Cancelar
      </button>
      <button
        id="save-category-button"
        type="submit"
        class="inline-flex min-h-11 items-center justify-center rounded-lg bg-accent px-5 text-sm font-semibold text-surface transition-colors hover:bg-accent-hover"
      >
        Guardar cambios
      </button>
    </div>
  </form>
</dialog>
